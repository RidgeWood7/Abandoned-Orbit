            <ui:Button text="&lt;&lt;" name="LeftButton" style="position: absolute; top: 17px; left: 2px; border-left-color: rgb(58, 58, 58); border-right-color: rgb(58, 58, 58); border-top-color: rgb(58, 58, 58); border-bottom-color: rgb(58, 58, 58);"/>
            <ui:Button text="&gt;&gt;" name="RightButton" style="position: absolute; top: 17px; left: 898px; border-left-color: rgb(58, 58, 58); border-right-color: rgb(58, 58, 58); border-top-color: rgb(58, 58, 58); border-bottom-color: rgb(58, 58, 58); height: auto; width: auto;"/>
